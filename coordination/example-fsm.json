{
    "@context": {
        "el": "https://secorolab.github.io/metamodels/behaviour/event_loop#",
        "fsm": "https://secorolab.github.io/metamodels/behaviour/fsm#",
        "hello": "https://example.com/hello#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
